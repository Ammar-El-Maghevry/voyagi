# =============================================================================
# Voyagi Backend — Environment Template
# =============================================================================
# Copy this file to `apps/backend/.env` for local development:
#   cp .env.example apps/backend/.env
# Never commit real secrets. Production values are injected via the platform's
# secret manager, not from this file.
# -----------------------------------------------------------------------------

# --- Application (Phase 1) ---------------------------------------------------
# Runtime environment: development | production | test
NODE_ENV=development
# HTTP port the API listens on.
PORT=3000
# Human-readable service name used in logs and Swagger.
APP_NAME=Voyagi API
# Maximum accepted request body size (e.g. 100kb, 1mb). In production it must be
# greater than zero and at most 10mb.
BODY_LIMIT=100kb
# Number of trusted reverse-proxy hops. Leave unset to disable proxy trust.
# In production only an explicit positive hop count is accepted — `true` is
# rejected so a spoofed X-Forwarded-For cannot shift anonymous rate-limit buckets.
# TRUST_PROXY=1

# --- Logging (Phase 1) -------------------------------------------------------
# Pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=debug
# Pretty-print logs for local development (true/false). MUST be false in
# production: pino-pretty is a dev-only dependency and is absent from the
# production image (which always logs JSON to stdout).
LOG_PRETTY=true

# --- CORS (Phase 1) ----------------------------------------------------------
# Comma-separated allowlist of browser origins. Leave empty to allow all in
# non-production and to deny all cross-origin requests in production.
CORS_ORIGINS=
# Allow credentials (cookies/authorization) on cross-origin requests.
CORS_CREDENTIALS=false

# --- Rate limiting (Phase 1) -------------------------------------------------
# Sliding window in milliseconds and the request budget per window per client.
RATE_LIMIT_TTL=60000
RATE_LIMIT_LIMIT=100

# --- API documentation (Phase 1) --------------------------------------------
# Expose Swagger UI (true/false). Defaults to enabled outside production.
SWAGGER_ENABLED=true
# Path where Swagger UI is served.
SWAGGER_PATH=api/docs

# --- Database (Phase 2) --------------------------------------------------------
# PostgreSQL connection string used by the backend's trusted server connection.
# SECRET: never commit a real value. In production this MUST be set explicitly
# (the app fails fast if it is missing). Outside production it defaults to the
# local Supabase stack shown below.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Name reported to PostgreSQL for this application's connections.
DATABASE_APP_NAME=voyagi-api
# Connection pool sizing.
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=10
# Timeouts (milliseconds).
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=30000
# Bounded timeout for the /health/ready database probe.
DATABASE_READINESS_TIMEOUT_MS=2000
# SSL mode: disable | require | no-verify | verify-ca | verify-full
# Defaults: disable (non-production), require (production). Use verify-full with
# a provided CA for the strongest production posture.
DATABASE_SSL_MODE=disable
# Development-only: log sanitized query metadata (never parameters). true/false.
DATABASE_LOG_QUERIES=false
# Warn when a query exceeds this duration in ms (metadata only, sanitized).
DATABASE_SLOW_QUERY_MS=500

# --- Supabase Auth (Phase 3) -------------------------------------------------
# Access tokens are verified asymmetrically against the Supabase JWKS endpoint
# (no shared secret is used or accepted). The issuer and JWKS URL default from
# SUPABASE_URL; in production SUPABASE_URL (or the explicit issuer/JWKS URLs
# below) MUST be set — the app fails fast when the JWKS URL cannot be resolved.
# Outside production these default to the local Supabase stack.
SUPABASE_URL=http://127.0.0.1:54321
# Optional explicit overrides. Leave unset to derive them from SUPABASE_URL.
# SUPABASE_JWT_ISSUER=http://127.0.0.1:54321/auth/v1
# SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json
# Expected audience claim (Supabase issues access tokens for `authenticated`).
SUPABASE_JWT_AUDIENCE=authenticated
# Comma-separated allow-list of asymmetric signing algorithms. Symmetric (HS*)
# and `none` are never accepted. Defaults to RS256,ES256.
# SUPABASE_JWT_ALGORITHMS=RS256,ES256
# Clock skew tolerance (seconds) applied to exp/nbf checks.
AUTH_CLOCK_TOLERANCE_SECONDS=5
# JWKS cache lifetime (ms) and bounded fetch timeout (ms).
AUTH_JWKS_CACHE_TTL_MS=600000
AUTH_JWKS_TIMEOUT_MS=5000
# Minimum interval (ms) before the JWKS is re-fetched on an unknown key id
# (key-rotation handling). Guards the endpoint against refetch storms.
AUTH_JWKS_COOLDOWN_MS=30000

# --- Payments (Phase 12 / 18.1) ----------------------------------------------
# Payment-provider registration mode: disabled | test
#  - production defaults to `disabled` (NO provider adapter is registered; all
#    payment mutations fail safely with 503 PAYMENT_PROVIDER_UNAVAILABLE) and
#    requires NO payment secret. `test` is REJECTED in production. No real
#    provider is integrated yet — real production payments remain BLOCKED.
#  - non-production defaults to `test`, which registers the deterministic
#    built-in TEST provider for local development and automated tests.
PAYMENTS_PROVIDER_MODE=test
# Shared secret for the TEST provider's webhook signature verification. SECRET:
# never commit a real value and never copy a shared production credential —
# generate your own unique local-only value. It is REQUIRED whenever test mode
# is enabled (there is NO random/ephemeral fallback and no runtime default): a
# missing, blank, known-placeholder (e.g. "secret", "changeme", "test",
# "voyagi-test-webhook-secret") or shorter-than-16-character value fails startup.
# It is NOT required when PAYMENTS_PROVIDER_MODE=disabled.
# PAYMENTS_TEST_WEBHOOK_SECRET=generate-your-own-unique-local-only-value

# --- Shutdown (Phase 18.1) ---------------------------------------------------
# Hard deadline (ms) for graceful shutdown before the process force-exits with a
# non-zero status. Bounded to 1000–120000; defaults to 15000. The hosting
# platform's stop grace period should be at least this value.
# SHUTDOWN_TIMEOUT_MS=15000

# --- Deployment / reverse proxy (Phase 18.1) ---------------------------------
# See TRUST_PROXY above. Behind a load balancer, set an explicit positive hop
# count so the client IP used for anonymous rate limiting is accurate.
# Production also requires an explicit CORS_ORIGINS allowlist and a non-local
# DATABASE_URL with DATABASE_SSL_MODE other than "disable".
